# ─────────────────────────────────────────────────────────
#  Angel One SmartAPI credentials
# ─────────────────────────────────────────────────────────
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_CODE=your_client_code_here
ANGEL_PASSWORD=your_password_here
# TOTP secret is the base-32 key from the QR code shown
# when you enabled 2FA in the Angel One app.
ANGEL_TOTP_SECRET=your_totp_secret_here

# ─────────────────────────────────────────────────────────
#  Telegram Bot
# ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─────────────────────────────────────────────────────────
#  Twilio WhatsApp (Sandbox)
# ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+919175447533

# ─────────────────────────────────────────────────────────
#  Application
# ─────────────────────────────────────────────────────────
# Default capital for paper trading / backtests
DEFAULT_CAPITAL=100000
# Port the FastAPI server listens on
APP_PORT=8000
# Add your LAN IP and/or Tailscale IP here (comma-separated) for mobile access
EXTRA_CORS_ORIGINS=
