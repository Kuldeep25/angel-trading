# ── Frontend ──────────────────────────────────────────────────────────────────
/frontend/dist/
/frontend/node_modules/
/frontend/.angular/cache/

# ── Backend ───────────────────────────────────────────────────────────────────
# Virtual environment
/backend/.venv/

# Secrets — never commit real credentials
/backend/.env

# Python cache
/backend/**/__pycache__/
/backend/**/*.pyc
/backend/**/*.pyo
/backend/**/*.pyd
/backend/.pytest_cache/
/backend/*.egg-info/

# Instrument master cache (large, auto-downloaded at startup)
/backend/angel/instruments_cache.json
/backend/angel/instruments_meta.json

# Runtime logs
/backend/logs/

# ── Misc ──────────────────────────────────────────────────────────────────────
build_out.txt
*.DS_Store
Thumbs.db